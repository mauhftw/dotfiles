#!/usr/bin/env bash
# Prior running this script you should login into your account

set -e

# TODO: Refactor everything into a for loop
# Set SSH dir
SSH_DIR="${HOME}/.ssh"
AWS_DIR="${HOME}/.aws"

# Check if SSH dir exists
if [[ -z $SSH_DIR ]]; then
  mkdir ${SSH_DIR}
fi

# Check if AWS dir exists
if [[ -z $AWS_DIR ]]; then
  mkdir ${AWS_DIR}
fi

# Update database
bw sync

# Get ssh keys from password manager
SSH_FOLDER_ID=$(bw list folders | jq -c '.[] | select(.name=="ssh") | .id ' | tr -d '"')
while  read -r name 
       read -r notes; do
       echo -e $notes > ${SSH_DIR}/${name}
       chmod 400 ${SSH_DIR}/${name}
done < <(bw list items ssh | jq -c '.[] | .name, .notes' | tr -d '"') 

# Get AWS configs form password manager
AWS_FOLDER_ID=$(bw list folders | jq -c '.[] | select(.name=="aws") | .id ' | tr -d '"')
while  read -r name 
       read -r notes; do
       echo -e $notes > ${AWS_DIR}/${name}
done < <(bw list items --folderid ${AWS_FOLDER_ID} | jq -c '.[] | .name, .notes' | tr -d '"') 
